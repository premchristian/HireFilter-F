"use client";

import { useState, useEffect, useRef } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { Search, Send, Image as ImageIcon, Paperclip, MoreVertical, Phone, Video, Info, User, Clock, Check, CheckCheck } from "lucide-react";

const INITIAL_CONTACTS = [
    {
        id: "1",
        name: "Sarah Williams",
        role: "Frontend Developer Candidate",
        avatar: "S",
        color: "from-blue-500 to-cyan-500",
        lastMessage: "Thanks for the interview opportunity!",
        time: "10:42 AM",
        unread: 2,
        status: "online"
    },
    {
        id: "2",
        name: "David Chen",
        role: "UX Designer",
        avatar: "D",
        color: "from-purple-500 to-pink-500",
        lastMessage: "I've attached my portfolio for review.",
        time: "Yesterday",
        unread: 0,
        status: "offline"
    },
    {
        id: "3",
        name: "Emily Rodriguez",
        role: "Product Manager Candidate",
        avatar: "E",
        color: "from-emerald-400 to-teal-500",
        lastMessage: "Can we reschedule our call?",
        time: "Mon",
        unread: 0,
        status: "online"
    },
    {
        id: "4",
        name: "Michael Chang",
        role: "Backend Engineer",
        avatar: "M",
        color: "from-orange-400 to-red-500",
        lastMessage: "The technical assignment is complete.",
        time: "Sun",
        unread: 0,
        status: "offline"
    }
];

const INITIAL_MESSAGES = {
    "1": [
        { id: "m1", senderId: "1", text: "Hi! I just submitted my application for the Frontend Developer role.", time: "10:30 AM", status: "read" },
        { id: "m2", senderId: "me", text: "Hello Sarah! Thanks for applying. We are currently reviewing your profile.", time: "10:35 AM", status: "read" },
        { id: "m3", senderId: "1", text: "That sounds great. Let me know if you need any more details.", time: "10:40 AM", status: "read" },
        { id: "m4", senderId: "1", text: "Thanks for the interview opportunity!", time: "10:42 AM", status: "delivered" },
    ]
};

export default function StandaloneChat({ userRole, userName }) {
    const [contacts, setContacts] = useState(INITIAL_CONTACTS);
    const [activeContact, setActiveContact] = useState(null);
    const [messages, setMessages] = useState(INITIAL_MESSAGES);
    const [newMessage, setNewMessage] = useState("");
    const [searchQuery, setSearchQuery] = useState("");
    const [isMobileListVisible, setIsMobileListVisible] = useState(true);
    const messagesEndRef = useRef(null);

    // Filter contacts based on search query
    const filteredContacts = contacts.filter(contact => 
        contact.name.toLowerCase().includes(searchQuery.toLowerCase()) || 
        contact.role.toLowerCase().includes(searchQuery.toLowerCase())
    );

    // Scroll to bottom when messages change
    useEffect(() => {
        messagesEndRef.current?.scrollIntoView({ behavior: "smooth" });
    }, [messages, activeContact]);

    const handleSendMessage = (e) => {
        e.preventDefault();
        if (!newMessage.trim() || !activeContact) return;

        const newMsgObj = {
            id: Date.now().toString(),
            senderId: "me",
            text: newMessage,
            time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
            status: "sent"
        };

        setMessages(prev => ({
            ...prev,
            [activeContact.id]: [...(prev[activeContact.id] || []), newMsgObj]
        }));

        // Update last message in contacts list
        setContacts(prev => prev.map(c => 
            c.id === activeContact.id 
                ? { ...c, lastMessage: newMessage, time: "Just now" } 
                : c
        ));

        setNewMessage("");

        // Simulate reply
        setTimeout(() => {
            const replyMsg = {
                id: (Date.now() + 1).toString(),
                senderId: activeContact.id,
                text: "Thank you for the message. I will get back to you shortly.",
                time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
                status: "delivered"
            };

            setMessages(prev => ({
                ...prev,
                [activeContact.id]: [...(prev[activeContact.id] || []), replyMsg]
            }));

            // Update contacts list again
            setContacts(curr => curr.map(c => 
                c.id === activeContact.id 
                    ? { ...c, lastMessage: replyMsg.text, time: "Just now", unread: (c.unread || 0) + 1 } 
                    : c
            ));
        }, 1500);
    };

    const handleContactSelect = (contact) => {
        setActiveContact(contact);
        setIsMobileListVisible(false); // Hide list on mobile
        
        // Mark as read
        setContacts(prev => prev.map(c => 
            c.id === contact.id ? { ...c, unread: 0 } : c
        ));
    };

    // Styling based on role (for neon accents)
    const getRoleAccentColor = () => {
        if (userRole === "admin") return "from-amber-400 to-orange-500";
        if (userRole === "candidate") return "from-[#EC4899] to-indigo-500";
        return "from-[#3B82F6] to-cyan-500"; // default HR
    };
    
    const getRoleRingColor = () => {
        if (userRole === "admin") return "ring-amber-500/50";
        if (userRole === "candidate") return "ring-[#EC4899]/50";
        return "ring-[#3B82F6]/50";
    };

    const getRoleBgColor = () => {
        if (userRole === "admin") return "bg-amber-500";
        if (userRole === "candidate") return "bg-[#EC4899]";
        return "bg-[#3B82F6]";
    };

    return (
        <div className="flex h-[calc(100vh-8rem)] bg-[#0A0E17]/50 lg:bg-[#131823] border border-white/5 rounded-2xl overflow-hidden backdrop-blur-xl shadow-2xl relative">
            
            {/* Sidebar (Contacts List) */}
            <div className={`w-full lg:w-96 flex-col border-r border-white/5 bg-[#0F141E]/50 lg:bg-transparent ${!isMobileListVisible ? 'hidden lg:flex' : 'flex'}`}>
                {/* Search Header */}
                <div className="p-4 lg:p-6 border-b border-white/5">
                    <h2 className="text-xl font-bold text-white mb-4">Messages</h2>
                    <div className="relative">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" />
                        <input 
                            type="text" 
                            placeholder="Search messages..." 
                            value={searchQuery}
                            onChange={(e) => setSearchQuery(e.target.value)}
                            className={`w-full bg-black/20 border border-white/10 rounded-xl pl-9 pr-4 py-2.5 text-sm text-white placeholder:text-gray-500 focus:outline-none focus:ring-1 ${getRoleRingColor()} transition-all`}
                        />
                    </div>
                </div>

                {/* Contacts List */}
                <div className="flex-1 overflow-y-auto scrollbar-hide">
                    {filteredContacts.length > 0 ? (
                        filteredContacts.map(contact => (
                            <button
                                key={contact.id}
                                onClick={() => handleContactSelect(contact)}
                                className={`w-full flex items-center gap-4 p-4 lg:p-5 border-b border-white/5 hover:bg-white/5 transition-all text-left ${activeContact?.id === contact.id ? 'bg-white/5' : ''}`}
                            >
                                <div className="relative">
                                    <div className={`w-12 h-12 rounded-full bg-linear-to-tr ${contact.color} flex items-center justify-center text-white font-bold text-lg shadow-lg`}>
                                        {contact.avatar}
                                    </div>
                                    {contact.status === 'online' && (
                                        <div className="absolute bottom-0 right-0 w-3 h-3 bg-emerald-500 rounded-full border-2 border-[#131823]"></div>
                                    )}
                                </div>
                                
                                <div className="flex-1 min-w-0">
                                    <div className="flex justify-between items-baseline mb-1">
                                        <h3 className="font-bold text-gray-100 truncate">{contact.name}</h3>
                                        <span className="text-xs text-gray-500 font-medium whitespace-nowrap ml-2">{contact.time}</span>
                                    </div>
                                    <div className="flex justify-between items-center gap-2">
                                        <p className="text-sm text-gray-400 truncate">{contact.lastMessage}</p>
                                        {contact.unread > 0 && (
                                            <span className={`w-5 h-5 rounded-full ${getRoleBgColor()} flex items-center justify-center text-[10px] font-bold text-white shrink-0 shadow-lg`}>
                                                {contact.unread}
                                            </span>
                                        )}
                                    </div>
                                </div>
                            </button>
                        ))
                    ) : (
                        <div className="p-8 text-center">
                            <div className="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-3">
                                <Search className="w-5 h-5 text-gray-500" />
                            </div>
                            <p className="text-gray-400 font-medium">No contacts found</p>
                        </div>
                    )}
                </div>
            </div>

            {/* Chat Area */}
            <div className={`flex-1 flex-col bg-[#131823] lg:flex ${isMobileListVisible ? 'hidden lg:flex' : 'flex'}`}>
                {activeContact ? (
                    <>
                        {/* Chat Header */}
                        <div className="px-4 lg:px-8 py-4 border-b border-white/5 flex justify-between items-center bg-[#0F141E]/30 backdrop-blur-md sticky top-0 z-10">
                            <div className="flex items-center gap-4">
                                <button 
                                    onClick={() => setIsMobileListVisible(true)}
                                    className="lg:hidden p-2 -ml-2 text-gray-400 hover:text-white rounded-xl hover:bg-white/5"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5"><path d="m15 18-6-6 6-6"/></svg>
                                </button>
                                
                                <div className={`w-10 h-10 rounded-full bg-linear-to-tr ${activeContact.color} flex items-center justify-center text-white font-bold`}>
                                    {activeContact.avatar}
                                </div>
                                <div>
                                    <h3 className="font-bold text-white leading-tight">{activeContact.name}</h3>
                                    <span className="text-xs text-gray-400 flex items-center gap-1.5 mt-0.5">
                                        {activeContact.status === "online" ? (
                                            <><span className="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Online</>
                                        ) : (
                                            <><span className="w-1.5 h-1.5 rounded-full bg-gray-500"></span> Offline</>
                                        )}
                                    </span>
                                </div>
                            </div>
                            
                            <div className="flex items-center gap-1 lg:gap-2 text-gray-400">
                                <button className="p-2 sm:p-2.5 hover:bg-white/5 rounded-full transition-colors hidden sm:block"><Phone className="w-4.5 h-4.5" /></button>
                                <button className="p-2 sm:p-2.5 hover:bg-white/5 rounded-full transition-colors hidden sm:block"><Video className="w-4.5 h-4.5" /></button>
                                <div className="w-px h-6 bg-white/10 mx-1 hidden sm:block"></div>
                                <button className="p-2 sm:p-2.5 hover:bg-white/5 rounded-full transition-colors"><Info className="w-4.5 h-4.5" /></button>
                            </div>
                        </div>

                        {/* Messages Area */}
                        <div className="flex-1 overflow-y-auto p-4 lg:p-8 space-y-6 scrollbar-hide">
                            <div className="flex justify-center mb-8">
                                <span className="px-3 py-1 bg-white/5 rounded-full text-xs font-medium text-gray-400 border border-white/5">
                                    Today
                                </span>
                            </div>
                            
                            {(messages[activeContact.id] || []).map((msg, index) => {
                                const isMe = msg.senderId === "me";
                                return (
                                    <motion.div 
                                        key={msg.id}
                                        initial={{ opacity: 0, y: 10 }}
                                        animate={{ opacity: 1, y: 0 }}
                                        className={`flex ${isMe ? 'justify-end' : 'justify-start'}`}
                                    >
                                        <div className={`max-w-[75%] lg:max-w-[65%] flex flex-col ${isMe ? 'items-end' : 'items-start'}`}>
                                            <div className={`px-5 py-3.5 rounded-2xl ${
                                                isMe 
                                                    ? `bg-linear-to-tr ${getRoleAccentColor()} text-white rounded-tr-none shadow-lg` 
                                                    : 'bg-white/5 text-gray-100 border border-white/5 rounded-tl-none shadow-sm'
                                            }`}>
                                                <p className="text-[15px] leading-relaxed">{msg.text}</p>
                                            </div>
                                            <div className="flex items-center gap-1.5 mt-1.5 text-gray-500 text-xs px-1">
                                                <span>{msg.time}</span>
                                                {isMe && (
                                                    <span className={msg.status === "read" ? "text-blue-400" : ""}>
                                                        {msg.status === "read" ? <CheckCheck className="w-3.5 h-3.5" /> : <Check className="w-3.5 h-3.5" />}
                                                    </span>
                                                )}
                                            </div>
                                        </div>
                                    </motion.div>
                                );
                            })}
                            <div ref={messagesEndRef} />
                        </div>

                        {/* Message Input */}
                        <div className="p-4 lg:p-6 bg-[#0F141E]/50 border-t border-white/5 backdrop-blur-md">
                            <form 
                                onSubmit={handleSendMessage}
                                className="flex items-end gap-3 bg-black/20 p-2 border border-white/10 rounded-2xl focus-within:border-white/20 focus-within:bg-black/40 transition-all shadow-inner"
                            >
                                <button type="button" className="p-2 sm:p-2.5 text-gray-400 hover:text-white rounded-xl hover:bg-white/5 transition-colors shrink-0">
                                    <Paperclip className="w-5 h-5" />
                                </button>
                                <textarea 
                                    value={newMessage}
                                    onChange={(e) => setNewMessage(e.target.value)}
                                    onKeyDown={(e) => {
                                        if (e.key === 'Enter' && !e.shiftKey) {
                                            e.preventDefault();
                                            handleSendMessage(e);
                                        }
                                    }}
                                    placeholder={`Message ${activeContact.name.split(' ')[0]}...`}
                                    className="flex-1 max-h-32 min-h-[44px] bg-transparent text-white placeholder:text-gray-500 resize-none outline-none py-2.5 text-[15px]"
                                    rows={1}
                                />
                                <button 
                                    type="submit"
                                    disabled={!newMessage.trim()}
                                    className={`p-2 sm:p-2.5 rounded-xl transition-all shrink-0 ${
                                        newMessage.trim() 
                                            ? `${getRoleBgColor()} text-white shadow-lg hover:brightness-110` 
                                            : 'bg-white/5 text-gray-600 cursor-not-allowed'
                                    }`}
                                >
                                    <Send className="w-5 h-5 ml-0.5" />
                                </button>
                            </form>
                            <div className="text-center mt-3">
                                <span className="text-[10px] text-gray-500 font-medium tracking-wide">Press Enter to send, Shift+Enter for new line</span>
                            </div>
                        </div>
                    </>
                ) : (
                    <div className="h-full flex flex-col items-center justify-center p-8 bg-gradient-to-b from-transparent to-black/10">

                        <h2 className="text-2xl font-bold text-white mb-2 tracking-tight">Your Messages</h2>
                        <p className="text-gray-400 max-w-sm text-center font-medium leading-relaxed">
                            Select a conversation from the sidebar to view history or start a new message.
                        </p>
                    </div>
                )}
            </div>
            
        </div>
    );
}
